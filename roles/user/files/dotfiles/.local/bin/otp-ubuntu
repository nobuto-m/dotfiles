#!/bin/bash

set -e
set -u

# To be invoked by a GNOME keyboard shortcut, in my case "Super + o"
# https://help.gnome.org/gnome-help/keyboard-shortcuts-set.html#custom

sec_attribute='application'
sec_value='otp-ubuntu'
otp_secret="$(secret-tool lookup "$sec_attribute" "$sec_value" || true)"

if [ -z "$otp_secret" ]; then
    if [ ! -t 0 ]; then
        notify-send 'OTP Ubuntu - No secret found' 'Use terminal to set the secret'
        exit 1
    else
        printf 'No existing secret found. Please enter the base32-encoded string:\n'
        read -r otp_secret
        [ -z "$otp_secret" ] && (printf 'No secret entered.\n'; exit 1)
        # verify it before saving it to the store
        oathtool --totp --base32 "$otp_secret"
        printf '%s' "$otp_secret" | secret-tool store --label 'OTP Ubuntu' "$sec_attribute" "$sec_value"
        exit
    fi
fi

otp=$(oathtool --totp --base32 "$otp_secret")

if [ ! -t 0 ] && which ydotool > /dev/null; then
    # From /usr/include/linux/input-event-codes.h, e.g.
    # #define KEY_LEFTCTRL  29
    # #define KEY_RIGHTCTRL 97
    keys_up_ctrl='29:0 97:0'
    keys_up_shift='42:0 54:0'
    keys_up_alt='56:0 100:0'
    keys_up_super='125:0 126:0'
    keys_clear_modifiers="$keys_up_ctrl $keys_up_shift $keys_up_alt $keys_up_super"
    keys_enter='28:1 28:0'
    keys_otp=
    while read -r -n 1 c; do
        case "$c" in
            [1-9])
                # KEY_1 2
                ec=$((c+1))
            ;;
            0)
                # KEY_0 11
                ec=11
            ;;
            *)
                break
            ;;
        esac
        keys_otp="$keys_otp $ec:1 $ec:0"
    done <<<"$otp"

    # Without quoting variables, it looks dangerous. However, $keys_otp
    # only contains predictable content as above.
    # shellcheck disable=SC2086
    ydotool key $keys_clear_modifiers $keys_otp $keys_enter
    exit
elif which xclip > /dev/null; then
    echo "$otp" | xclip -selection clip
fi
echo "$otp"
