* xremap
  - https://github.com/xremap/xremap/releases/download/v0.15.5/xremap-linux-x86_64-socket.zip
  - `sudo useradd --no-create-home --shell /bin/false --user-group --groups input --system xremap`
  - `sudo mkdir -p /etc/xremap`
  - `sudo chown xremap:xremap /etc/xremap/config.yml`
  - `sudo chmod 644 /etc/xremap/config.yml`
  - `sudo groupadd --system xremap-$USER`
  - `sudo usermod --append --groups xremap-$USER $USER`
  - `/etc/systemd/system/xremap.service`
  - `sudo systemctl enable xremap.service`
  # similar with /usr/lib/udev/rules.d/80-uinput.rules by ydotool
  # or /lib/udev/rules.d/60-steam-input.rules
  - `echo 'KERNEL=="uinput", GROUP="input", TAG+="uaccess", MODE:="0660", OPTIONS+="static_node=uinput"' | sudo tee /etc/udev/rules.d/99-input.rules`
